# Copy to .env.local and fill in values
# These override site.config.ts at runtime (useful for multi-site deployments)

# Vercel environment variables — set these in the Vercel dashboard
# NEXT_PUBLIC_AMAZON_TAG=yourname-20
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Mailchimp — set these after creating your free Mailchimp account
# 1. Log in to Mailchimp → Account → Extras → API Keys → Create a Key
# 2. Copy the API key below
# 3. MAILCHIMP_LIST_ID: Audience → Settings → Audience name and defaults → Audience ID
# 4. MAILCHIMP_SERVER_PREFIX: last part of your API key after the dash (e.g., "us17")
# MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us17
# MAILCHIMP_LIST_ID=abc123def4
# MAILCHIMP_SERVER_PREFIX=us17
